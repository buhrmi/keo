{
  "name": "inertiax",
  "private": true,
  "type": "module",
  "scripts": {
    "build:all": "bun -r --filter './packages/*' build",
    "dev": "bunx concurrently -c \"#b794f4,#61dafb,#d43008,#32a06f,#bd34fe,#ffa800\" \"bun dev:core\" \"bun dev:svelte\" \"bun dev:vite\" --names=core,svelte,vite",
    "dev:core": "cd packages/core && bun run dev",
    "dev:vite": "cd packages/vite && bun run dev",
    "dev:vue": "cd packages/vue3 && bun run dev",
    "dev:react": "cd packages/react && bun run dev",
    "dev:svelte": "cd packages/svelte && bun run dev",
    "dev:test-app": "bunx concurrently -c \"#61dafb,#d43008,#32a06f\" \"bun dev:test-app:react\" \"bun dev:test-app:svelte\" \"bun dev:test-app:vue\" --names=react,svelte,vue",
    "dev:test-app:react": "bunx concurrently -c \"#c4b5fd,#ffa800\" \"cd tests/app && PACKAGE=react bun serve:watch\" \"cd packages/react/test-app && bun run dev\" --names=server,vite",
    "dev:test-app:svelte": "bunx concurrently -c \"#c4b5fd,#ffa800\" \"cd tests/app && PACKAGE=svelte bun serve:watch\" \"cd packages/svelte/test-app && bun run dev\" --names=server,vite",
    "dev:test-app:vue": "bunx concurrently -c \"#c4b5fd,#ffa800\" \"cd tests/app && PACKAGE=vue3 bun serve:watch\" \"cd packages/vue3/test-app && bun run dev\" --names=server,vite",
    "es2022-check": "bun -r --filter './packages/*' es2022-check",
    "lint:test-app": "bun -r --filter './packages/*/test-app' lint",
    "lint:test-app:react": "cd packages/react/test-app && bun run lint",
    "lint:test-app:svelte": "cd packages/svelte/test-app && bun run lint",
    "lint:test-app:vue": "cd packages/vue3/test-app && bun run lint",
    "type-check:test-app": "bun -r --filter './packages/*/test-app' type-check",
    "type-check:test-app:react": "cd packages/react/test-app && bun run type-check",
    "type-check:test-app:svelte": "cd packages/svelte/test-app && bun run type-check",
    "type-check:test-app:vue": "cd packages/vue3/test-app && bun run type-check",
    "test:react": "PACKAGE=react node playwright.js",
    "test:svelte": "PACKAGE=svelte node playwright.js",
    "test:vue": "PACKAGE=vue3 node playwright.js",
    "test:ssr:react": "PACKAGE=react SSR=true bunx playwright test",
    "test:ssr:svelte": "PACKAGE=svelte SSR=true bunx playwright test",
    "test:ssr:vue": "PACKAGE=vue3 SSR=true bunx playwright test",
    "test:vite": "cd packages/vite && bun test",
    "playground:react": "cd playgrounds/react && ./init.sh && composer run dev",
    "playground:svelte": "cd playgrounds/svelte5 && ./init.sh && composer run dev",
    "playground:vue": "cd playgrounds/vue3 && ./init.sh && composer run dev",
    "format": "oxfmt"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0"
  },
  "engines": {
    "bun": ">=11.1.1"
  }
}
