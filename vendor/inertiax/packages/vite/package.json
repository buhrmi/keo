{
  "name": "inertiax-vite",
  "version": "3.3.0",
  "license": "MIT",
  "description": "Vite plugin for Inertia.js with SSR dev mode support.",
  "contributors": [
    "Pascal Baljet <pascal@laravel.com>"
  ],
  "homepage": "https://inertiajs.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/buhrmi/inertiax.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/buhrmi/inertiax/issues"
  },
  "files": [
    "dist",
    "types"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun clean && ./build.js && tsc",
    "clean": "rm -rf types && rm -rf dist",
    "dev": "bunx concurrently -c \"#ffcf00,#3178c6\" \"bun dev:build\" \"bun dev:types\" --names build,types",
    "dev:build": "./build.js --watch",
    "dev:types": "tsc --watch --preserveWatchOutput",
    "test": "vitest run"
  },
  "dependencies": {
    "inertiax": "file:../core",
    "tinyglobby": "^0.2.15"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  },
  "devDependencies": {
    "@types/estree": "^1.0.8",
    "@types/node": "^24.10.13",
    "esbuild": "^0.27.3",
    "esbuild-node-externals": "^1.20.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.2"
  }
}
